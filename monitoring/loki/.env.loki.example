# ============================================
# Loki Configuration Environment Variables
# ============================================
# Copy this file to .env.loki and fill in your values
# NEVER commit .env.loki to version control!

# ============================================
# Grafana Cloud Configuration
# Get these from: https://grafana.com/orgs/<your-org>/stacks/<stack>
# ============================================

# Loki endpoint (e.g., logs-prod-us-central1.grafana.net)
GRAFANA_CLOUD_LOKI_HOST=logs-prod-us-central1.grafana.net

# Loki user ID (numeric, shown in the Loki datasource settings)
GRAFANA_CLOUD_LOKI_USER=123456

# Grafana Cloud API key (needs 'MetricsPublisher' role)
GRAFANA_CLOUD_API_KEY=glc_eyYourApiKeyHere

# ============================================
# Optional: Local Grafana (if not using Grafana Cloud)
# ============================================
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change-me-in-production

# ============================================
# Promtail Configuration
# ============================================
PROMTAIL_HTTP_PORT=9080
PROMTAIL_LOG_LEVEL=info

# ============================================
# External Labels (applied to all logs)
# ============================================
CLUSTER_NAME=zaplit-prod
REGION=us-central1
ENVIRONMENT=production

# ============================================
# Retention Settings (for self-hosted Loki)
# ============================================
LOKI_RETENTION_DAYS=30
