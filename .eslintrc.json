{
  "$schema": "https://json.schemastore.org/eslintrc",
  "root": true,
  "extends": [
    "eslint:recommended"
  ],
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "dist/",
    "*.config.js",
    "*.config.mjs",
    "*.config.ts"
  ],
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
  }
}
