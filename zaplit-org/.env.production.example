# Production Environment Configuration
# Copy this file to .env.production and fill in real values
# DO NOT commit .env.production to git

# n8n Webhook URLs - Use production n8n instance
N8N_WEBHOOK_CONSULTATION=https://n8n.zaplit.com/webhook/consultation
N8N_WEBHOOK_CONTACT=https://n8n.zaplit.com/webhook/contact
N8N_WEBHOOK_NEWSLETTER=https://n8n.zaplit.com/webhook/newsletter

# Webhook Secret - Generate with: openssl rand -hex 32
# Store actual value in GCP Secret Manager
N8N_WEBHOOK_SECRET=__SECRET_FROM_GCP_SECRET_MANAGER__

# IP Hash Salt - Required for GDPR compliance
# Generate with: openssl rand -hex 32
# Must be consistent across all instances
IP_HASH_SALT=__SECRET_FROM_GCP_SECRET_MANAGER__

# Sentry DSN for error tracking
SENTRY_DSN=__SECRET_FROM_GCP_SECRET_MANAGER__

# Logo.dev API Token
NEXT_PUBLIC_LOGO_TOKEN=__SECRET_FROM_GCP_SECRET_MANAGER__

NODE_ENV=production
PORT=8080
