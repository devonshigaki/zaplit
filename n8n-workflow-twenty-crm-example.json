{
  "name": "Twenty CRM Lead Capture Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "twenty-lead-capture",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Lead Form Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "webhookId": "twenty-lead-capture"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.twenty.com/rest/companies?filter={"domainName":{"eq":"{{ $json.body.domain || $json.body.companyDomain }}"}}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "search-company",
      "name": "Search Company by Domain",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-1",
              "leftValue": "={{ $json.data.companies.length }}",
              "rightValue": "0",
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-company-exists",
      "name": "Company Exists?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Company exists - extract ID from first result\nconst companies = $input.first().json.data.companies;\nreturn {\n  json: {\n    companyId: companies[0].id\n  }\n};"
      },
      "id": "extract-company-id",
      "name": "Extract Company ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        850,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.twenty.com/rest/companies",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": "={\"name\": \"{{ $json.body.companyName }}\", \"domainName\": \"{{ $json.body.domain || $json.body.companyDomain }}\"}",
        "options": {}
      },
      "id": "create-company",
      "name": "Create Company",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        400
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Extract company ID from created company\nreturn {\n  json: {\n    companyId: $input.first().json.data.id\n  }\n};"
      },
      "id": "extract-new-company-id",
      "name": "Extract New Company ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1050,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.twenty.com/rest/people",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": "={\"name\": {\"firstName\": \"{{ $json.firstName || $json.body.firstName }}\", \"lastName\": \"{{ $json.lastName || $json.body.lastName }}\"}, \"email\": \"{{ $json.email || $json.body.email }}\", \"phone\": \"{{ $json.phone || $json.body.phone }}\", \"jobTitle\": \"{{ $json.jobTitle || $json.body.jobTitle }}\", \"companyId\": \"{{ $json.companyId }}\"}",
        "options": {}
      },
      "id": "create-person",
      "name": "Create Person",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1250,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.twenty.com/rest/notes",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": "={\"title\": \"Lead from Website\", \"body\": \"{{ $json.body.message || 'No message provided' }}\", \"personId\": \"{{ $json.data.id }}\", \"companyId\": \"{{ $json.body.companyId }}\"}",
        "options": {}
      },
      "id": "create-note",
      "name": "Create Note",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1450,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      }
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "merge-data",
      "name": "Merge Data",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2.1,
      "position": [
        1050,
        300
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"status\": \"success\", \"message\": \"Lead captured successfully\", \"personId\": \"{{ $json.data.id }}\", \"companyId\": \"{{ $json.body.companyId }}\"}",
        "options": {}
      },
      "id": "success-response",
      "name": "Success Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1650,
        300
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"status\": \"error\", \"message\": \"Failed to process lead\"}",
        "options": {}
      },
      "id": "error-response",
      "name": "Error Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1450,
        500
      ]
    }
  ],
  "pinData": {},
  "settings": {
    "executionOrder": "v1"
