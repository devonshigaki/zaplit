        "method": "POST",
        "url": "https://api.twenty.com/rest/companies/batch",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": "={\"records\": [{\"name\": \"Batch Company 1\", \"domainName\": \"batch1.com\"}, {\"name\": \"Batch Company 2\", \"domainName\": \"batch2.com\"}]}",
        "options": {}
      },
      "name": "11. Batch Create",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1450,
