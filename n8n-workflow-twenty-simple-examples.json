        "method": "POST",
        "url": "https://api.twenty.com/rest/notes",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": "={\"title\": \"Follow-up Required\", \"body\": \"Contacted via website form. Interested in enterprise plan.\"}",
        "options": {}
      },
      "name": "6. Create Note",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        950,
        100
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      },
