{
  "name": "Twenty CRM Simple API Examples",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "seconds",
              "secondsInterval": 60
            }
          ]
        }
      },
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.twenty.com/rest/companies",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": "={\"name\": \"Example Company {{ $now.format('YYYY-MM-DD HH:mm') }}\", \"domainName\": \"example-{{ $now.format('YYYYMMDDHHmm') }}.com\", \"employees\": 50}",
        "options": {}
      },
      "name": "1. Create Company",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        100
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      },
      "notes": "Creates a new company in Twenty CRM"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.twenty.com/rest/companies",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "name": "2. List Companies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      },
      "notes": "Fetches list of all companies"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.twenty.com/rest/companies?filter={"name":{"like":"%Example%"}}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "name": "3. Search Companies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        500
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      },
      "notes": "Search companies by name using filter"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.twenty.com/rest/people",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": "={\"name\": {\"firstName\": \"John\", \"lastName\": \"Doe\"}, \"email\": \"john.doe@example.com\", \"jobTitle\": \"Sales Manager\"}",
        "options": {}
      },
      "name": "4. Create Person",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        700,
        100
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      },
      "notes": "Creates a contact/person in Twenty CRM"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.twenty.com/rest/people",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "name": "5. List People",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        700,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      },
      "notes": "Fetches list of all contacts/people"
