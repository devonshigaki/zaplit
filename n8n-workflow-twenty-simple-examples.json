      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Twenty CRM API"
        }
      },
      "notes": "Search for person by email address"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.twenty.com/rest/tasks",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": "={\"title\": \"Follow up with new lead\", \"dueAt\": \"{{ $now.plus({days: 1}).toISO() }}\", \"status\": \"TODO\"}",
        "options": {}
      },
      "name": "9. Create Task",
      "type": "n8n-nodes-base.httpRequest",
