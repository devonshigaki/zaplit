# =============================================================================
# n8n - Twenty CRM Integration: Security Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# 1. ENCRYPTION KEY (CRITICAL - BACKUP SECURELY)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 16
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key encrypts all credentials in n8n. If lost, credentials are unrecoverable.
N8N_ENCRYPTION_KEY=your-32-character-encryption-key-here-minimum-length

# -----------------------------------------------------------------------------
# 2. WEBHOOK SECURITY
# -----------------------------------------------------------------------------
# Bearer token for webhook authentication
# Generate with: openssl rand -hex 32
WEBHOOK_BEARER_TOKEN=your-webhook-bearer-token-here

# Alternative: API Key for webhook authentication
WEBHOOK_API_KEY=your-webhook-api-key-here

# HMAC Secret for signature verification (most secure)
# Generate with: openssl rand -hex 64
WEBHOOK_HMAC_SECRET=your-hmac-secret-here-very-long-string

# -----------------------------------------------------------------------------
# 3. TWENTY CRM API CREDENTIALS
# -----------------------------------------------------------------------------
# These should be configured via n8n UI, not environment variables
# But can be used for initial setup or specific use cases
TWENTY_CRM_API_KEY=your-twenty-crm-api-key
TWENTY_CRM_BASE_URL=https://api.twenty.com

# -----------------------------------------------------------------------------
# 4. SECURITY MONITORING
# -----------------------------------------------------------------------------
# Slack configuration for security alerts
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SECURITY_CHANNEL=#security-alerts

# Email configuration for security alerts
SECURITY_TEAM_EMAIL=security@yourcompany.com
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=your-smtp-password

# -----------------------------------------------------------------------------
# 5. DATA RETENTION (GDPR Compliance)
# -----------------------------------------------------------------------------
# Enable automatic pruning of execution data
EXECUTIONS_DATA_PRUNE=true

# Maximum age of execution data (hours)
# 168 = 7 days (GDPR recommended)
# 336 = 14 days (default)
EXECUTIONS_DATA_MAX_AGE=168

# Maximum number of executions to keep (0 = unlimited)
EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000

# Save settings
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_PROGRESS=false
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=false

# -----------------------------------------------------------------------------
# 6. PRIVACY / TELEMETRY
# -----------------------------------------------------------------------------
# Disable n8n telemetry for privacy
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false

# -----------------------------------------------------------------------------
# 7. DATABASE SECURITY
# -----------------------------------------------------------------------------
# Use PostgreSQL in production (not SQLite)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=your-secure-database-password

# Enable SSL/TLS for database connections
DB_POSTGRESDB_SSL_ENABLED=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=true

# -----------------------------------------------------------------------------
# 8. NETWORK SECURITY
# -----------------------------------------------------------------------------
# n8n instance URL (must be HTTPS in production)
N8N_HOST=n8n.yourcompany.com
N8N_PROTOCOL=https
N8N_PORT=5678

# Proxy configuration (if behind reverse proxy)
N8N_PROXY_HOPS=1

# -----------------------------------------------------------------------------
# 9. LOGGING
# -----------------------------------------------------------------------------
# Log level: error, warn, info, verbose, debug
N8N_LOG_LEVEL=info

# Log output file
N8N_LOG_FILE=/var/log/n8n/n8n.log

# -----------------------------------------------------------------------------
# 10. SESSION SECURITY
# -----------------------------------------------------------------------------
# Session timeout in seconds (15 minutes = 900)
N8N_AUTH_SESSION_TIMEOUT=900

# Remember session for X days
N8N_AUTH_SESSION_REFRESH_TIMEOUT=7
