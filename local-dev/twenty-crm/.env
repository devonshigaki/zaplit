# Docker Image Tag
TAG=latest

# Database Configuration
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=twentypassword123
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432
PG_DATABASE_NAME=default

# Redis Configuration
REDIS_URL=redis://redis:6379

# Server URL - MUST match how users access the application
# Using port 3001 to avoid conflict with Next.js on 3000
SERVER_URL=http://localhost:3001

# Application Secret - Generate with: openssl rand -base64 32
# IMPORTANT: Must be at least 32 characters!
APP_SECRET=twenty_local_dev_secret_key_32_chars_long

# Storage Configuration
STORAGE_TYPE=local
