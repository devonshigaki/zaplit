    {
      "parameters": {
        "jsCode": "// Validate and parse form data\nconst body = $input.first().json.body;\nconst errors = [];\n\n// Validation\nif (!body.data?.email) errors.push('Email is required');\nif (!body.data?.name) errors.push('Name is required');\n\n// Email format validation\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (body.data?.email && !emailRegex.test(body.data.email)) {\n  errors.push('Invalid email format');\n}\n\nif (errors.length > 0) {\n  return [{ json: { valid: false, errors, data: null }}];\n}\n\n// Name parsing with edge case handling\nconst nameStr = body.data.name?.trim() || 'Unknown';\nconst nameParts = nameStr.split(/\\s+/);\nconst firstName = nameParts[0];\nconst lastName = nameParts.length > 1 ? nameParts.slice(1).join(' ') : '';\n\n// Format arrays for note\nconst formatArray = (arr) => {\n  if (!Array.isArray(arr) || arr.length === 0) return 'None specified';\n  return arr.join(', ');\n};\n\n// Sanitize string inputs\nconst sanitize = (str) => {\n  if (!str) return 'Not specified';\n  return str.replace(/[<>]/g, '').substring(0, 1000);\n};\n\nreturn [{\n  json: {\n    valid: true,\n    person: {\n      firstName: sanitize(firstName),\n      lastName: sanitize(lastName),\n      email: body.data.email.toLowerCase().trim(),\n      jobTitle: sanitize(body.data.role)\n    },\n    company: {\n      name: sanitize(body.data.company) || 'Unknown Company'\n    },\n    note: {\n      title: `Consultation: ${sanitize(body.data.company) || 'Unknown'}`,\n      message: sanitize(body.data.message),\n      teamSize: sanitize(body.data.teamSize),\n      techStack: formatArray(body.data.techStack),\n      securityLevel: sanitize(body.data.securityLevel),\n      compliance: formatArray(body.data.compliance)\n    }\n  }\n}];"
      },
