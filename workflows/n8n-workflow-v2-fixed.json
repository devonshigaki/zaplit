        "jsCode": "// Extract IDs from CRM responses\nconst input = $input.first().json;\n\n// Person data from Create Person response (input[0])\nconst personData = input[0];\nconst personId = personData?.data?.id;\n\n// Company data from Create Company response (input[1])\nconst companyData = input[1];\nconst companyId = companyData?.data?.id;\n\n// Original form data (stored in input[0] from previous nodes)\nconst formData = $input.all()[0].json;\n\nreturn [{\n  json: {\n    personId: personId,\n    companyId: companyId,\n    person: formData.person,\n    company: formData.company,\n    note: formData.note\n  }\n}];"
