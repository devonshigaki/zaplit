# Google Sheets Integration Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# GOOGLE SHEETS CONFIGURATION (Required for form backup)
# =============================================================================

# Your Google Sheet ID (from the URL)
# Example: If URL is https://docs.google.com/spreadsheets/d/ABC123/edit
# Then GOOGLE_SHEETS_SPREADSHEET_ID=ABC123
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here

# Name of the sheet tab (default: "Submissions")
GOOGLE_SHEETS_SHEET_NAME=Submissions

# Enable/disable the backup (set to "true" to enable)
ENABLE_GOOGLE_SHEETS_BACKUP=false

# Path to service account key file (LOCAL DEVELOPMENT ONLY)
# For Cloud Run, this is NOT needed - uses Workload Identity instead
GOOGLE_APPLICATION_CREDENTIALS=/path/to/form-submitter-key.json

# =============================================================================
# FEATURE FLAGS (For migration control)
# =============================================================================

# Enable Twenty CRM integration
ENABLE_TWENTY_CRM=false

# Enable n8n webhook (set to "false" to disable while n8n is initializing)
ENABLE_N8N_WEBHOOK=true

# =============================================================================
# N8N WEBHOOK URLs (Optional - when n8n is ready)
# =============================================================================

N8N_WEBHOOK_CONSULTATION=https://your-n8n-instance.com/webhook/consultation
N8N_WEBHOOK_CONTACT=https://your-n8n-instance.com/webhook/contact
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/form-submission

# Optional: Secret for webhook verification
N8N_WEBHOOK_SECRET=your-secret-key-here

# =============================================================================
# TWENTY CRM CONFIGURATION (Optional)
# =============================================================================

TWENTY_BASE_URL=http://localhost:3001
TWENTY_API_KEY=your-twenty-api-key
