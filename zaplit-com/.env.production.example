# Production Environment Configuration
# Copy this file to .env.production and fill in real values
# DO NOT commit .env.production to git

# =============================================================================
# CRITICAL: N8N Webhook Configuration
# =============================================================================
# These webhooks receive form submissions from the website
# Configure these in your n8n instance first, then paste the URLs here

N8N_WEBHOOK_CONSULTATION=https://n8n.zaplit.com/webhook/consultation-form-v4
N8N_WEBHOOK_CONTACT=https://n8n.zaplit.com/webhook/contact-form
N8N_WEBHOOK_NEWSLETTER=https://n8n.zaplit.com/webhook/newsletter-signup
N8N_WEBHOOK_URL=https://n8n.zaplit.com/webhook/fallback

# Webhook Secret - Generate with: openssl rand -hex 32
# This secures webhook calls between the app and n8n
# Store actual value in GCP Secret Manager
N8N_WEBHOOK_SECRET=__SECRET_FROM_GCP_SECRET_MANAGER__

# =============================================================================
# CRITICAL: Twenty CRM Configuration
# =============================================================================
# The CRM receives leads from n8n workflows
# Get API key from: Twenty CRM → Settings → API Keys

TWENTY_BASE_URL=https://crm.zaplit.com
TWENTY_API_KEY=__SECRET_FROM_GCP_SECRET_MANAGER__

# =============================================================================
# CRITICAL: Security & Privacy
# =============================================================================
# IP Hash Salt - Required for GDPR-compliant IP address hashing
# Generate with: openssl rand -hex 32
# MUST be identical across all deployed instances
IP_HASH_SALT=__SECRET_FROM_GCP_SECRET_MANAGER__

# =============================================================================
# Brevo Email Configuration
# =============================================================================
# Transactional email service for confirmations and notifications
# Get API key from: Brevo Dashboard → Settings → SMTP & API → API Keys

BREVO_API_KEY=__SECRET_FROM_GCP_SECRET_MANAGER__
BREVO_SMTP_KEY=__SECRET_FROM_GCP_SECRET_MANAGER__
BREVO_SENDER_EMAIL=noreply@zaplit.com
BREVO_SENDER_NAME="Zaplit Team"
BREVO_WEBHOOK_SECRET=__SECRET_FROM_GCP_SECRET_MANAGER__

# =============================================================================
# Monitoring & Error Tracking
# =============================================================================

SENTRY_DSN=__SECRET_FROM_GCP_SECRET_MANAGER__
NEXT_PUBLIC_SENTRY_DSN=__SECRET_FROM_GCP_SECRET_MANAGER__

# =============================================================================
# Redis (Optional - for distributed rate limiting)
# =============================================================================
# If not configured, falls back to in-memory rate limiting

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# =============================================================================
# Third-party Services
# =============================================================================

# Logo.dev API Token for company logos
LOGO_DEV_TOKEN=__SECRET_FROM_GCP_SECRET_MANAGER__

# =============================================================================
# Infrastructure
# =============================================================================

NODE_ENV=production
SERVICE_NAME=zaplit-com
PORT=8080

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# INTEGRATION CHECKLIST
# =============================================================================
# Before deploying to production, verify:
#
# [ ] n8n webhooks created and URLs updated above
# [ ] N8N_WEBHOOK_SECRET generated and in GCP Secret Manager
# [ ] Twenty CRM API key generated and in GCP Secret Manager
# [ ] IP_HASH_SALT generated and in GCP Secret Manager
# [ ] Brevo API key generated and in GCP Secret Manager
# [ ] Sentry DSN created and in GCP Secret Manager
# [ ] Redis configured (or confirm in-memory fallback is acceptable)
# [ ] All secrets stored in GCP Secret Manager, NOT in this file
# [ ] DKIM DNS record added for email (mail._domainkey.zaplit.com)
# [ ] PTR record requested from GCP for mail.zaplit.com
#
# =============================================================================
